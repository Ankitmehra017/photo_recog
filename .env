# Public URL guests will see in their gallery link.
# For local use only, leave as-is.
# For ngrok: set to your ngrok URL, e.g. https://abc123.ngrok-free.app
# GALLERY_BASE_URL=http://localhost:8000
GALLERY_BASE_URL= https://reason-tag-handclap.ngrok-free.dev

# Full path to the folder containing wedding photos on THIS computer.
# Mac example:     /Users/sarah/Desktop/WeddingPhotos
# Windows example: C:\Users\Sarah\Desktop\WeddingPhotos
# Leave as-is if you'll upload photos via the web UI instead.
PHOTOS_FOLDER=./empty_photos
