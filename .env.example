# Public URL guests will see in their gallery link.
# For local use only, leave as-is.
# For ngrok: set to your ngrok URL, e.g. https://abc123.ngrok-free.app
GALLERY_BASE_URL=http://localhost:8000

# Password to access the photographer upload page (/upload).
# Leave empty to disable password protection.
PHOTOGRAPHER_PASSWORD=photographer@123

# Separate password required to reset all data (photos, guests, matches).
# If not set, falls back to PHOTOGRAPHER_PASSWORD.
# Set this to give reset control to a specific person (e.g. event organiser).
RESET_PASSWORD=reset@123
